root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space

[*.{rs,toml}]
indent_size = 4

[*.{c,cpp,h,hpp,inc,def}]
indent_size = 4

[CMakeLists.txt]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.{cmd,bat,ps1}]
end_of_line = crlf
indent_size = 4

[Makefile]
indent_style = tab
